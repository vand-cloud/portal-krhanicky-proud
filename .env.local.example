# Sanity write token (jediny povinny env var)
# Project ID + dataset jsou hardcoded v sanity/env.ts (klient vand-cloud, 4nb8kl4e).
SANITY_WRITE_TOKEN=

# Resend (zatim neaktivni, doplnime pri zapnuti formularu)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Public site URL: lokalne dev URL, na Vercelu se prepise na produkcni domenu
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional overrides (pro testovani proti jinemu Sanity projektu / datasetu)
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=
# SANITY_API_VERSION=
